NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Gideon content-seeding cron (gideon/) ---
# Reddit source: free "script" app at https://www.reddit.com/prefs/apps (app-only OAuth).
# Without these the Reddit source no-ops (returns []); all other sources still run.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
# GitHub source: optional personal-access token to raise the search rate limit
# (works keyless otherwise). In GitHub Actions the auto-provided GITHUB_TOKEN is used.
GITHUB_TOKEN=your_github_token
# Optional Gideon tuning:
GIDEON_MAX_POSTS_PER_GENRE=5    # posts inserted per genre per run (default 5)
# GIDEON_RESET=1                # wipe existing Gideon posts before a refetch
