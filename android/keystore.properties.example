# Copy this file to android/keystore.properties and fill in real values.
# keystore.properties is gitignored — never commit your signing secrets.
#
# Generate the keystore ONCE (keep the file + passwords safe forever; the same
# key must sign every future build or updates won't install over the old app):
#
#   cd android
#   keytool -genkey -v -keystore techdate.keystore -alias techdate \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Then point storeFile at it (path is relative to the android/ folder):

storeFile=techdate.keystore
storePassword=CHANGE_ME
keyAlias=techdate
keyPassword=CHANGE_ME
